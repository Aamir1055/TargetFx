<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Enable proxy for WebSocket (must come BEFORE regular API proxy)
  RewriteCond %{HTTP:Upgrade} =websocket [NC]
  RewriteCond %{HTTP:Connection} =Upgrade [NC]
  RewriteRule ^api/broker/ws(.*)$ ws://api.brokereye.work.gd/api/broker/ws$1 [P,L]

  # Enable proxy for regular API requests
  RewriteCond %{REQUEST_URI} ^/api/
  RewriteRule ^api/(.*)$ http://api.brokereye.work.gd/api/$1 [P,L]
  
  # Skip rewrite for static assets (js, css, images, fonts, etc)
  RewriteCond %{REQUEST_URI} \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|map)$ [NC]
  RewriteRule ^ - [L]
  
  # Don't rewrite files or directories that exist
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Only serve SPA fallback for the frontend domain, not the API domain
  RewriteCond %{HTTP_HOST} !^api\.brokereye\.work\.gd$ [NC]
  
  # Rewrite everything else to index.html to allow html5 state links
  RewriteRule ^ index.html [L]
</IfModule>
